        "initiatedDate": { "type": "string", "format": "date", "required": true },
        "completedDate": { "type": "string", "format": "date", "required": false },
        "status": { "type": "string", "enum": ["pending", "in_progress", "completed", "adverse_action", "cleared"], "required": true },
